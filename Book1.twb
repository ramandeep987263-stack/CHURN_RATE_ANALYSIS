      <column caption='Calculation1' datatype='real' name='[Calculation_0759910740406272]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#10;IF [Churn] = &quot;Yes&quot; THEN 1 ELSE 0 END&#10;)&#10;/&#10;COUNT([customerID])' />
